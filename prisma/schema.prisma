// Prisma schema for the Sales Performance Dashboard.
// Postgres (Supabase), connected via the pooled connection for app queries
// and the direct connection for migrations/db push (see .env.example).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Snapshot {
  id          String   @id @default(cuid())
  uploadedAt  DateTime @default(now())
  reportTitle String
  data        String // JSON-serialized Dataset (see lib/types.ts)

  @@index([uploadedAt])
}

enum Role {
  ADMIN
  VIEWER
  TEAM_LEADER
}

enum UserStatus {
  PENDING
  APPROVED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         Role       @default(VIEWER)
  status       UserStatus @default(APPROVED) // admin-created users are pre-approved; self-registered rows start PENDING
  allowedPages String[]   @default([]) // report page keys this user can see; ignored for ADMIN (always full access)
  teamLeaderId String?    @unique // links a TEAM_LEADER-role login to their TeamLeader row; unused for ADMIN/VIEWER
  createdAt    DateTime   @default(now())
}

// Admin-editable content for automated emails (currently just the new-modules
// announcement — see lib/email.ts's ANNOUNCEMENT_TEMPLATE_KEY). One row per
// email "key". Absence of a row (first run, or after "Reset to original")
// means the caller falls back to that email's DEFAULT_*_SUBJECT/BODY
// constants in lib/email.ts rather than erroring.
model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Admin-maintained monthly targets, uploaded via a small dedicated form
// (app/(protected)/admin/targets) independent of the big Sales/Stock/Coverage
// refresh cycle. Overlaid onto Dataset.monthlySales[].target at read time by
// lib/datasetStore.ts, not baked into the Snapshot JSON blob at upload time.
model Target {
  id                 String   @id @default(cuid())
  year               String
  month              String
  monthIndex         Int
  principal          String
  mainPrincipal      String?
  valueTarget        Float?
  volumeTarget       Float?
  coverageTarget     Float?
  productivityTarget Float?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([year, month, principal])
  @@index([year, month])
}

// One row per edit made through the Monthly Targets entry form (app/(protected)/
// admin/targets), mirroring the source Target_Per_Principal_System.xlsm workbook's
// AuditTrail sheet. `changes` holds { field: { old, new } } for whichever of the
// 4 target fields moved in that save — not written by the bulk-upload path, only
// the row-level Add/Edit/Delete form.
model TargetAuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userEmail String
  action    String // "CREATE" | "UPDATE" | "DELETE"
  year      String
  month     String
  principal String
  changes   Json

  @@index([year, month, principal])
}

// Team Leader roster — one row per team leader, optionally linked to a login
// (User.teamLeaderId) once they have one. Admin-editable via /admin/team-leaders.
model TeamLeader {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// The "fact table" driving Weekly Targets: which reps, selling which principals,
// report up through which team leader. Admin-editable via /admin/team-leaders.
// A rep can appear under multiple principals, and (matrix orgs) under different
// team leaders per principal. This table is the source of truth for which
// (teamLeaderId, principal) pairs get a Weekly Target grid, and which reps are
// eligible for that principal's RepContribution split.
model TeamLeaderAssignment {
  id           String   @id @default(cuid())
  teamLeaderId String
  employeeCode String
  employeeName String
  principal    String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([teamLeaderId, employeeCode, principal])
  @@index([teamLeaderId])
  @@index([principal])
}

// Admin-editable reference data (rarely changes), consumed by scripts/db-bridge
// as the item->principal/pack-size join for the SQL bridge, replacing the
// earlier network-share Excel read.
model Product {
  id             String   @id @default(cuid())
  itemNo         String   @unique
  packSize       Float?
  principal      String
  costPrice      Float?
  classification String?
  ssuConversion  Float?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// Admin-editable reference data (rarely changes), consumed by scripts/db-bridge
// as the warehouse->location join for the SQL bridge.
model Warehouse {
  id            String   @id @default(cuid())
  warehouseCode String   @unique
  warehouseName String
  location      String
  locationCode  String
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// Admin-editable reference data (rarely changes). Not currently consumed by
// scripts/db-bridge's transforms or any dashboard view — kept for completeness
// alongside Product/Warehouse.
model KeyAccountRep {
  id         String   @id @default(cuid())
  rep        String   @unique
  channel    String
  teamLeader String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// Monthly Sales (Revenue/COGS/Gross Profit) sourced directly from SAP SQL Server
// (scripts/db-bridge, YTD_Raw), pushed live via app/api/sales/upload. Unlike
// Target/PLEntry, this fully REPLACES Dataset.monthlySales at read time rather
// than merging a single field — once rows exist here, the Excel-sourced Sales
// figures in the Snapshot blob are no longer used (Target still overlays on top,
// same as before). Coverage/Brand&Customer/Stock/Weekly Projection remain
// Excel-sourced; this table intentionally covers Sales only.
model SalesRecord {
  id            String   @id @default(cuid())
  year          String
  month         String
  monthIndex    Int
  location      String
  principal     String
  revenue       Float
  cogs          Float
  grossProfit   Float
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([year, month, principal])
  @@index([year, month])
}

// P&L journal-entry lines from SAP (OJDT/JDT1 by Cost Centre/Account), pushed
// live by scripts/pl-bridge (not shadow-only, unlike scripts/db-bridge) via
// app/api/pl/upload. Aggregated to Year+Month+Principal+AccountCode+LineType
// grain before storage — never one row per raw JE line. Overlaid onto
// Dataset.monthlyPL at read time by lib/datasetStore.ts, same pattern as Target.
model PLEntry {
  id          String   @id @default(cuid())
  year        String
  month       String
  monthIndex  Int
  principal   String // Cost Centre — same raw Principal-Location string as MonthlySalesRow.principal
  accountCode String
  accountName String
  lineType    String // "REVENUE" | "COGS" | "EXPENSE" | "OTHER_INCOME"
  amount      Float
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([year, month, principal, accountCode, lineType])
  @@index([year, month])
}

// Active Outlets — outlet-level YTD purchase-event summary from the "pine"
// field-force DB, one row per Year+Principal+CustomerID, pushed live by
// scripts/db-bridge/active-outlets via app/api/active-outlets/upload. Read
// directly by app/(protected)/(analytics)/active-outlets/page.tsx — not part
// of Dataset/Snapshot, since this has no Excel-sourced equivalent. Powers
// outlet drill-down plus Channel/Sub Channel/Frequency-Band breakdowns,
// aggregated live from this table rather than pre-baked.
model ActiveOutlet {
  id                 String   @id @default(cuid())
  year               String
  principal          String // Cost Centre, matches other principal fields' raw string
  customerId         String // pine.outlets o_id
  outletName         String
  channel            String
  subChannel         String
  territory          String
  salesRole          String // dominant role for the period: "Primary Sales" | "Secondary Sales"
  timesBought        Int
  purchaseDays       Int
  activeMonths       Int
  firstPurchaseDate  DateTime
  lastPurchaseDate   DateTime
  frequencyBand      String // e.g. "One-time Buyer", "Regular - About Monthly"
  sales              Float
  qty                Float
  mostRecentRep      String?
  mostRecentRepGroup String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([year, principal, customerId])
  @@index([year, principal])
}

// Monthly trend for Active Outlets: distinct outlets per Cost Centre, split
// Primary/Secondary, RE-COUNTED per month — never derived by summing
// ActiveOutlet rows across months (same "unique not repeated sums" rule
// already established for Coverage; see project memory).
model ActiveOutletMonthly {
  id              String   @id @default(cuid())
  year            String
  month           String
  monthIndex      Int
  principal       String
  salesRole       String
  distinctOutlets Int
  transactions    Int
  sales           Float
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([year, month, principal, salesRole])
  @@index([year, month])
}

// Timestamps — one row per rep-outlet-day call from the "pine" field-force DB,
// current calendar month only (deliberately, matching the source script's own
// design). Full table replace every sync (scripts/db-bridge/active-outlets via
// app/api/timestamps/upload) — this table always holds "this month," never
// accumulates history, same precedent as PLEntry's full-aggregate-then-replace.
// Rep-daily summaries (First/Last Call, Strike Rate %, Outlets Covered) are
// aggregated live from this table on read, not stored separately.
model RepCall {
  id                String   @id @default(cuid())
  date              DateTime
  employeeCode      String
  salesRep          String
  employeeGroup     String
  salesRole         String
  region            String
  callSequence      Int
  callTime          DateTime
  callOutcome       String // "Sale" | "No Sale"
  noSaleReason      String?
  outletId          String
  outletName        String
  channel           String
  subChannel        String
  territory         String
  costCentresBought String // comma-joined, matches the source script's "Cost Centres Bought"
  intervalMins      Float? // minutes since this rep's previous call that day; null for the first
  documents         Int
  sales             Float
  qty               Float
  firstCallOfDay    DateTime
  lastCallOfDay     DateTime
  hoursInDay        Float
  callsInDay        Int
  productiveInDay   Int
  createdAt         DateTime @default(now())

  @@unique([date, employeeCode, outletId])
  @@index([date])
  @@index([employeeCode, date])
}

// Journey Plan — one row per planned rep x outlet x date, derived from the
// "pine" field-force DB's historical visit-frequency + geo-sweep route/home-day
// algorithm (scripts/db-bridge/jp-adherence), pushed live via
// app/api/jp-adherence/upload/plan. Route/frequency is COMPUTED from a
// trailing 90-day lookback every sync (LOOKBACK_DAYS in run.ts) so it reflects
// a rep's current territory, but only the most recent RECENT_UPLOAD_DAYS (7)
// worth of rows are actually persisted here — the first live run generated
// 800K+ rows across the full 90 days (862 reps x ~65 workdays), which is both
// impractical to serve on a page load and far more history than the page's
// route table is ever used for. JP Adherence Daily/Monthly Split (below)
// stay full-90-day-scoped since they're small aggregates, not raw per-visit
// rows. Full table replace every sync (not upsert-on-key, unlike
// ActiveOutlet) — a planned row that falls out of the rolling window must
// disappear, not linger forever, same precedent as RepCall.
// costCentre/principalCostCentre is always the real per-line principal (e.g.
// "Mars-Nairobi"), never the internal "Key Accounts" multi-Cost-Centre-rep
// grouping token used only inside the route algorithm.
model JourneyPlanRow {
  id                  String   @id @default(cuid())
  costCentreGroup     String // "Key Accounts" for multi-CC reps, else the bare Cost Centre
  principalCostCentre String // the rep's actual per-line Cost Centre, e.g. "Mars-Nairobi"
  salesRole           String
  userGroup           String
  employeeCode        String
  employeeName        String
  monthLabel          String // "Jul-2026"
  day                 String // "Monday".."Friday"
  date                DateTime
  weekOfMonth         Int
  dayIndex            Int // 0=Mon..4=Fri
  routeSeq            Int
  customerId          String
  customerName        String
  territory           String
  latitude            Float?
  longitude           Float?
  visitsPerWeek       Int
  minOutletsTarget    Int
  dayOutletCount      Int
  status              String // "OK" | "BELOW TARGET"
  createdAt           DateTime @default(now())

  @@unique([date, employeeCode, customerId])
  @@index([date])
  @@index([employeeCode, date])
}

// JP Adherence — one row per Date+Employee comparing planned vs actual visit
// activity (scripts/db-bridge/jp-adherence, build_jp_adherence's jp_summary
// shape), pushed live via app/api/jp-adherence/upload/adherence. Full table
// replace every sync, same rationale as JourneyPlanRow.
model JPAdherenceDaily {
  id                 String   @id @default(cuid())
  date               DateTime
  monthLabel         String
  employeeCode       String
  employeeName       String
  userGroup          String
  salesRole          String
  costCentre         String
  outletsPlanned     Int
  outletsVisited     Int
  jpAdherencePct     Float
  productiveOutlets  Int
  strikeRatePct      Float
  plannedNotVisited  Int
  visitedNotPlanned  Int
  totalActualVisits  Int
  status             String // "Excellent" | "Good" | "Below Target"
  createdAt          DateTime @default(now())

  @@unique([date, employeeCode])
  @@index([date])
  @@index([employeeCode, date])
}

// JP Adherence Detail — one row per planned-or-unplanned visit event, backing
// the page's rep-day drill-down (lazy-loaded via app/api/jp-adherence/detail,
// not shipped on initial page load). JPAdherenceDaily's own aggregates are
// computed from the FULL 90-day detail set in-memory during the sync, before
// this table is trimmed for storage — see JourneyPlanRow's comment for why
// only the most recent RECENT_UPLOAD_DAYS (7) are actually persisted here
// (the full 90-day detail set hit 1M+ rows on the first live run). Full
// table replace every sync, same rationale as JourneyPlanRow.
model JPAdherenceDetail {
  id                  String   @id @default(cuid())
  date                DateTime
  monthLabel          String
  day                 String
  employeeCode        String
  employeeName        String
  userGroup           String
  salesRole           String
  costCentre          String
  principalCostCentre String
  customerId          String
  customerName        String
  territory           String
  plannedFlag         Boolean
  visitedFlag         Boolean
  productiveFlag      Boolean
  visitType           String
  revenue             Float
  qty                 Float // no carton-conversion data is plumbed into this bridge (unlike the Python reference's Converter.xlsx) — raw units, matching RepCall/ActiveOutlet's own qty convention
  jpStatus            String // "Planned & Productive" | "Planned & Visited" | "Planned Not Visited" | "Unplanned Visit"
  latitude            Float?
  longitude           Float?
  createdAt           DateTime @default(now())

  @@unique([date, employeeCode, customerId])
  @@index([date])
  @@index([employeeCode, date])
}

// Monthly Split — Month x CostCentre x SalesRole x Rep x ActivityStatus flat
// rows (no Sub Total/TOTAL, per the source script's design), from
// scripts/db-bridge/jp-adherence's buildMonthlySplit, pushed via
// app/api/jp-adherence/upload/monthly-split. Full table replace every sync,
// same rationale as JourneyPlanRow — reflects only the trailing 90-day
// window, not a persistent YTD history.
model JPMonthlySplitRow {
  id              String   @id @default(cuid())
  monthLabel      String // "Jul-2026"
  monthIndex      Int
  year            String
  costCentre      String
  salesRole       String
  employeeCode    String
  employeeName    String
  activityStatus  String // "Active" | "Inactive"
  coverage        Int
  productive      Int
  productivityPct Float
  revenue         Float
  qty             Float // see JPAdherenceDetail.qty comment — no carton-conversion data in this bridge
  createdAt       DateTime @default(now())

  @@unique([monthLabel, costCentre, salesRole, employeeCode, activityStatus])
  @@index([monthLabel])
  @@index([employeeCode])
}

// Weekly revenue targets per Team Leader x Principal x Week, entered via
// /weekly-targets (replicates WeeklyTargetEntry_MacroSystem.xlsm). Grid rows are
// lazily generated (up to "today + 8 weeks") only for (teamLeaderId, principal)
// pairs present in TeamLeaderAssignment — not a blind cross-product of every team
// leader x every principal like the source workbook, so Filled/Pending % stays
// meaningful. Week convention matches the source file: 5 calendar-weeks-of-month,
// Monday-start, "Apr Week 1"-style labels kept alongside weekStartDate (the real,
// unambiguous key). Historical weeks stay editable indefinitely — no locking.
model WeeklyTarget {
  id             String   @id @default(cuid())
  teamLeaderId   String
  principal      String
  year           String
  monthLabel     String
  weekLabel      String
  weekStartDate  DateTime
  targetValue    Float    @default(0)
  lastModifiedBy String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([teamLeaderId, principal, weekStartDate])
  @@index([teamLeaderId, weekStartDate])
  @@index([weekStartDate])
}

// One row per edit made through the Weekly Targets grid, same shape/rationale as
// TargetAuditLog.
model WeeklyTargetAuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  userEmail     String
  action        String // "CREATE" | "UPDATE" | "DELETE"
  teamLeaderId  String
  principal     String
  weekStartDate DateTime
  changes       Json

  @@index([teamLeaderId, weekStartDate])
}

// Contribution-by-Rep — each rep's share of a principal's trailing revenue among
// reps assigned to that principal (TeamLeaderAssignment), computed from
// JPMonthlySplitRow as the final step of scripts/db-bridge/jp-adherence/run.ts.
// Full table replace every computation (not upsert-on-key), same rationale as
// JPMonthlySplitRow itself — reflects only the current trailing window. Drives
// the read-time rep-level split of Monthly/Weekly targets (repTarget =
// principalTarget x sharePct) and the weekday-weighted DailyTarget below.
model RepContribution {
  id             String   @id @default(cuid())
  principal      String
  employeeCode   String
  employeeName   String
  teamLeaderId   String?
  quarterRevenue Float
  sharePct       Float
  computedAt     DateTime @default(now())

  @@unique([principal, employeeCode])
  @@index([principal])
}

// Daily Projection — each rep's WeeklyTarget split across weekdays by their own
// productive-visit-count histogram from the preceding calendar week
// (JPAdherenceDetail.productiveFlag), falling back to their trailing-90-day
// histogram, then an even weekday split, if that history is too sparse (same
// layered-fallback shape as JP Adherence's home-day derivation). Persisted
// (unlike the read-time-only rep-level Monthly/Weekly split) because reps need a
// fast "today's number" read and the weekday-weight computation is worth doing
// once rather than per page view. Full-replace per (employeeCode, principal,
// week) whenever the parent WeeklyTarget is saved, and again on each JP
// Adherence sync to roll the preceding-week pattern forward.
model DailyTarget {
  id                String   @id @default(cuid())
  employeeCode      String
  employeeName      String
  principal         String
  teamLeaderId      String
  date              DateTime
  targetValue       Float
  weeklyTargetId    String
  sharePctUsed      Float
  weekdayWeightUsed Float
  createdAt         DateTime @default(now())

  @@unique([employeeCode, principal, date])
  @@index([date])
  @@index([employeeCode, date])
}

// Daily AI-generated executive digest — one row per generation run, produced by
// /api/ai-insights/generate (Claude Sonnet 5) from current Sales-vs-Target and
// Sync Health data, then displayed on /dashboard so it doesn't need
// regenerating on every page view. findings is JSON-serialized
// AiInsightFinding[] (see lib/aiInsights.ts) rather than a relational table —
// a small, display-only structure with no need for independent querying.
model AiInsight {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  summary     String
  findings    String // JSON-serialized AiInsightFinding[]
  model       String // the Claude model ID that produced this digest

  @@index([generatedAt])
}
