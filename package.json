{
  "name": "sales-performance-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:seed": "node prisma/seed.mjs",
    "db:push": "prisma db push",
    "db-bridge:run": "tsx scripts/db-bridge/run.ts",
    "db-bridge:compare": "tsx scripts/db-bridge/compare.ts",
    "db-bridge:coverage-run": "tsx scripts/db-bridge/coverage/run.ts",
    "db-bridge:coverage-compare": "tsx scripts/db-bridge/coverage/compare.ts",
    "pl:sync": "tsx scripts/pl-bridge/run.ts",
    "sales:sync": "tsx scripts/db-bridge/sales-sync.ts",
    "active-outlets:sync": "tsx scripts/db-bridge/active-outlets/run.ts",
    "jp-adherence:sync": "tsx scripts/db-bridge/jp-adherence/run.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "overrides": {
    "next-auth": {
      "nodemailer": "$nodemailer"
    }
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.331",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "mssql": "^12.7.0",
    "mysql2": "^3.22.6",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
