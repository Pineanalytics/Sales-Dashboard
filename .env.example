# Supabase Postgres connection strings for project "pinefrostsales"
# (ref: addexxjwrxmjjqmcwkib, region: eu-west-1).
# Get the real values from the Supabase dashboard: Project Settings > Connect
# > ORMs tab > Prisma. It gives you both strings pre-filled with your password.
DATABASE_URL="postgresql://postgres.addexxjwrxmjjqmcwkib:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.addexxjwrxmjjqmcwkib:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-random-32-byte-base64-secret"

# Optional: lets a headless script call POST /api/upload without an interactive admin
# session (e.g. a scheduled export from the source Excel workbook). Sent as the
# x-upload-api-key header. Leave unset to disable this auth path entirely.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
UPLOAD_API_KEY=""

# Optional: only needed to run scripts/db-bridge (shadow-validation SQL bridge, not used
# by the running app). Dedicated read-only SQL Server login for PINEFROSTSERVER/GVS_PL_DB.
# Only reachable from the office LAN, so this only works run from that machine.
SQLBRIDGE_SQL_SERVER="PINEFROSTSERVER"
SQLBRIDGE_SQL_DATABASE="GVS_PL_DB"
SQLBRIDGE_SQL_USER=""
SQLBRIDGE_SQL_PASSWORD=""
SQLBRIDGE_SQL_ENCRYPT="false"
SQLBRIDGE_SQL_TRUST_SERVER_CERT="true"

# Optional: only needed to run scripts/db-bridge/coverage (shadow-validation only, not
# used by the running app). A MySQL database (NOT SQL Server) backing a separate
# field-force/SFA system, unrelated to SQLBRIDGE_SQL_* above.
SQLBRIDGE_COVERAGE_MYSQL_HOST=""
SQLBRIDGE_COVERAGE_MYSQL_PORT="3306"
SQLBRIDGE_COVERAGE_MYSQL_USER=""
SQLBRIDGE_COVERAGE_MYSQL_PASSWORD=""
SQLBRIDGE_COVERAGE_MYSQL_DATABASE=""

# Optional: only used by scripts/pl-bridge/run.ts (npm run pl:sync) to know where to
# POST live P&L data. Reuses SQLBRIDGE_SQL_* for the SQL Server connection and
# UPLOAD_API_KEY above for auth — this just overrides the target app URL if needed.
# Defaults to https://pinefrostdb.netlify.app when unset.
PL_BRIDGE_APP_URL=""
